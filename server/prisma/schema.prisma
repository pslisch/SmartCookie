datasource db {
  provider = "mysql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
  ARCHIVED
  LOCKED
}

model User {
  id            String     @id @default(uuid())
  username      String?    @unique
  email         String?    @unique
  passwordHash  String?
  isSuperuser   Boolean    @default(false)
  isSuperuserUnique Boolean? @map("is_superuser_unique")
  recoveryEmail String?
  companyId     String?
  company       Company?   @relation(fields: [companyId], references: [id])
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  sessions      Session[]
  tokens        Token[]
  roleId        String?    @map("role_id")
  role          Role?      @relation(fields: [roleId], references: [id])
  memberships        Membership[] @relation("UserMemberships")
  createdMemberships Membership[] @relation("MembershipCreator")
  createdAssignments Assignment[] @relation("AssignmentCreator")
  ownedAssignments   Assignment[] @relation("AssignmentOwner")
  assignmentTargets  AssignmentTarget[] @relation("UserAssignmentTargets")
  userAssignmentInstances UserAssignmentInstance[] @relation("UserAssignmentInstances")
  auditLogs          AuditLog[] @relation("UserAuditLogs")
  createdContents    Content[]  @relation("ContentCreator")

  firstName          String?    @map("first_name")
  lastName           String?    @map("last_name")
  profilePicturePath String?    @map("profile_picture_path")
  lastLoginAt        DateTime?  @map("last_login_at")
  profileFieldValues ProfileFieldValue[]
  notificationPreferences NotificationPreference[]
  mfaEnabled          Boolean    @default(false) @map("mfa_enabled")
  mfaSecretEncrypted  String?    @map("mfa_secret_encrypted")
  mfaEnabledAt        DateTime?  @map("mfa_enabled_at")
  mfaRecoveryCodes    MfaRecoveryCode[]

  entraObjectId             String?    @map("entra_object_id")
  profilePictureManuallySet Boolean    @default(false) @map("profile_picture_manually_set")
  triggeredSyncLogs         SyncLog[]  @relation("SyncLogTriggerer")

  @@unique([isSuperuserUnique], name: "is_superuser_unique_idx")
  @@unique([companyId, entraObjectId])
  @@map("users")
}

enum TokenPurpose {
  INVITATION
  PASSWORD_RESET
  EMAIL_CHANGE
  MFA_CHALLENGE
}

model Token {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String       @unique
  purpose      TokenPurpose
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime     @default(now())
  pendingEmail String?      @map("pending_email")

  @@map("tokens")
}

model Company {
  id                         String                   @id @default(uuid())
  name                       String
  contactInfo                String
  setupCompletedAt           DateTime?
  roleInheritanceEnabled     Boolean                  @default(false) @map("role_inheritance_enabled")
  users                      User[]
  roles                      Role[]
  domain                     String                   @default("")
  settings                   Json?
  organizationUnits          OrganizationUnit[]
  learningGroups             LearningGroup[]
  lessons                    Lesson[]
  courses                    Course[]
  assignments                Assignment[]
  auditLogs                  AuditLog[]
  contentCategories          ContentCategory[]
  contents                   Content[]
  mandatoryNotificationTypes Json?                    @map("mandatory_notification_types")
  profileFieldCategories     ProfileFieldCategory[]
  profileFieldDefinitions    ProfileFieldDefinition[]
  mfaPolicy                  MfaPolicy                @default(DISABLED) @map("mfa_policy")
  mfaPolicyRoles             MfaPolicyRole[]
  identityProviderConfigs    IdentityProviderConfig[]
  entraGroupSelections       EntraGroupSelection[]
  syncLogs                   SyncLog[]

  @@map("companies")
}

model Role {
  id             String                @id @default(uuid())
  name           String
  isProtected    Boolean               @default(false) @map("is_protected")
  parentRoleId   String?               @map("parent_role_id")
  parentRole     Role?                 @relation("RoleInheritance", fields: [parentRoleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  childRoles     Role[]                @relation("RoleInheritance")
  companyId      String                @map("company_id")
  company        Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  users          User[]
  permissions    RolePermission[]
  fieldEditables FieldEditableByRole[]
  mfaPolicyRoles MfaPolicyRole[]
  identityProviderConfigs IdentityProviderConfig[]

  @@map("roles")
}

model Permission {
  id             String           @id @default(uuid())
  module         String
  action         String
  roles          RolePermission[]

  @@unique([module, action], name: "module_action_idx")
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  @@map("sessions")
}

model OrganizationUnit {
  id                String             @id @default(uuid())
  name              String
  companyId         String             @map("company_id")
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentId          String?            @map("parent_id")
  parent            OrganizationUnit?  @relation("OUHierarchy", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  children          OrganizationUnit[] @relation("OUHierarchy")
  deletedAt         DateTime?          @map("deleted_at")
  permanentDeleteAt DateTime?          @map("permanent_delete_at")
  deletionBatchId   String?            @map("deletion_batch_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  memberships       Membership[]
  assignmentTargets AssignmentTarget[]
  assignmentInstanceSources UserAssignmentInstanceSource[] @relation("SourceOrganizationUnit")

  syncSource        SyncSource         @default(MANUAL) @map("sync_source")
  entraGroupId      String?            @map("entra_group_id")

  @@unique([companyId, entraGroupId])
  @@map("organization_units")
}

enum GroupType {
  STATIC
  DYNAMIC
}

model LearningGroup {
  id                String             @id @default(uuid())
  name              String
  companyId         String             @map("company_id")
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentGroupId     String?            @map("parent_group_id")
  parentGroup       LearningGroup?     @relation("GroupHierarchy", fields: [parentGroupId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  childGroups       LearningGroup[]    @relation("GroupHierarchy")
  type              GroupType          @default(STATIC)
  isTemporary       Boolean            @default(false) @map("is_temporary")
  expiresAt         DateTime?          @map("expires_at")
  reminderSentAt    DateTime?          @map("reminder_sent_at")
  deletedAt         DateTime?          @map("deleted_at")
  permanentDeleteAt DateTime?          @map("permanent_delete_at")
  deletionBatchId   String?            @map("deletion_batch_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  memberships       Membership[]
  assignmentTargets AssignmentTarget[]
  assignmentInstanceSources UserAssignmentInstanceSource[] @relation("SourceLearningGroup")

  @@map("learning_groups")
}

enum MembershipType {
  MEMBER
  MANAGER
}

enum MembershipStatus {
  ACTIVE
  PENDING
  ARCHIVED
}

enum MembershipSource {
  MANUAL
  AZURE_AD
  LDAP
  HR_IMPORT
  API
}

model Membership {
  id                  String             @id @default(uuid())
  userId              String             @map("user_id")
  user                User               @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  organizationUnitId  String?            @map("organization_unit_id")
  organizationUnit    OrganizationUnit?  @relation(fields: [organizationUnitId], references: [id], onDelete: Cascade)
  learningGroupId     String?            @map("learning_group_id")
  learningGroup       LearningGroup?     @relation(fields: [learningGroupId], references: [id], onDelete: Cascade)
  membershipType      MembershipType     @map("membership_type")
  status              MembershipStatus   @default(ACTIVE)
  source              MembershipSource   @default(MANUAL)
  createdById         String             @map("created_by_id")
  createdBy           User               @relation("MembershipCreator", fields: [createdById], references: [id])
  deletedAt           DateTime?          @map("deleted_at")
  deletionBatchId     String?            @map("deletion_batch_id")
  createdAt           DateTime           @default(now()) @map("created_at")

  @@map("memberships")
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
}

enum CompletionRule {
  MARKED_COMPLETE
  QUIZ_PASSED
  MIN_SCORE
  ACKNOWLEDGEMENT
  CUSTOM
}

enum AssignmentType {
  IMMEDIATE
  SCHEDULED
}

enum AssignmentStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  CANCELLED
  ARCHIVED
}

model Lesson {
  id                   String           @id @default(uuid())
  companyId            String           @map("company_id")
  company              Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title                String
  status               LessonStatus     @default(DRAFT)
  version              Int              @default(1)
  prerequisiteLessonId String?          @map("prerequisite_lesson_id")
  prerequisiteLesson   Lesson?          @relation("LessonPrerequisites", fields: [prerequisiteLessonId], references: [id], onDelete: SetNull)
  dependentLessons     Lesson[]         @relation("LessonPrerequisites")
  completionRule       CompletionRule   @default(MARKED_COMPLETE) @map("completion_rule")
  contentId            String?          @map("content_id")
  content              Content?         @relation(fields: [contentId], references: [id], onDelete: SetNull)
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  courseLessons        CourseLesson[]
  assignments          Assignment[]

  @@map("lessons")
}

model Course {
  id            String         @id @default(uuid())
  companyId     String         @map("company_id")
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title         String
  status        CourseStatus   @default(DRAFT)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  courseLessons CourseLesson[]

  @@map("courses")
}

model CourseLesson {
  courseId  String   @map("course_id")
  lessonId  String   @map("lesson_id")
  order     Int
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@id([courseId, lessonId])
  @@map("course_lessons")
}

model Assignment {
  id                      String             @id @default(uuid())
  companyId               String             @map("company_id")
  company                 Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lessonId                String             @map("lesson_id")
  lesson                  Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  assignmentType          AssignmentType     @map("assignment_type")
  scheduledFor            DateTime?          @map("scheduled_for")
  dueDateDefaultDays      Int?               @map("due_date_default_days")
  isMandatory             Boolean            @default(false) @map("is_mandatory")
  createdById             String             @map("created_by_id")
  createdBy               User               @relation("AssignmentCreator", fields: [createdById], references: [id])
  ownerId                 String             @map("owner_id")
  owner                   User               @relation("AssignmentOwner", fields: [ownerId], references: [id])
  status                  AssignmentStatus   @default(DRAFT)
  attemptLimit            Int                @default(0) @map("attempt_limit")
  courseAssignmentBatchId String?            @map("course_assignment_batch_id")
  deletedAt               DateTime?          @map("deleted_at")
  permanentDeleteAt       DateTime?          @map("permanent_delete_at")
  deletionBatchId         String?            @map("deletion_batch_id")
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  targets                 AssignmentTarget[]
  userAssignmentInstances UserAssignmentInstance[]

  @@map("assignments")
}

model AssignmentTarget {
  id                 String            @id @default(uuid())
  assignmentId       String            @map("assignment_id")
  assignment         Assignment        @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId             String?           @map("user_id")
  user               User?             @relation("UserAssignmentTargets", fields: [userId], references: [id], onDelete: Cascade)
  organizationUnitId String?           @map("organization_unit_id")
  organizationUnit   OrganizationUnit? @relation(fields: [organizationUnitId], references: [id], onDelete: Cascade)
  learningGroupId    String?           @map("learning_group_id")
  learningGroup      LearningGroup?    @relation(fields: [learningGroupId], references: [id], onDelete: Cascade)
  createdAt          DateTime          @default(now()) @map("created_at")

  @@map("assignment_targets")
}

enum UserAssignmentInstanceStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum AssignmentSourceType {
  MANUAL
  ORGANIZATION_UNIT
  LEARNING_GROUP
  SELF_ASSIGNED
  MANDATORY
  API
}

model UserAssignmentInstance {
  id                String                       @id @default(uuid())
  assignmentId      String                       @map("assignment_id")
  assignment        Assignment                   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId            String                       @map("user_id")
  user              User                         @relation("UserAssignmentInstances", fields: [userId], references: [id], onDelete: Cascade)
  status            UserAssignmentInstanceStatus @default(ACTIVE)
  dueDate           DateTime?                    @map("due_date")
  startedAt         DateTime?                    @map("started_at")
  completedAt       DateTime?                    @map("completed_at")
  contentId         String?                      @map("content_id")
  content           Content?                     @relation(fields: [contentId], references: [id], onDelete: SetNull)

  progressPercent   Int                          @default(0) @map("progress_percent")
  deletedAt         DateTime?                    @map("deleted_at")
  permanentDeleteAt DateTime?                    @map("permanent_delete_at")
  deletionBatchId   String?                      @map("deletion_batch_id")
  lastReminderSentAt DateTime?                   @map("last_reminder_sent_at")
  createdAt         DateTime                     @default(now()) @map("created_at")
  updatedAt         DateTime                     @updatedAt @map("updated_at")
  sources           UserAssignmentInstanceSource[]
  contentAttempts   ContentAttempt[]

  @@unique([assignmentId, userId])
  @@map("user_assignment_instances")
}

model UserAssignmentInstanceSource {
  id                       String                 @id @default(uuid())
  userAssignmentInstanceId String                 @map("user_assignment_instance_id")
  userAssignmentInstance   UserAssignmentInstance @relation(fields: [userAssignmentInstanceId], references: [id], onDelete: Cascade)
  sourceType               AssignmentSourceType   @map("source_type")
  sourceOrganizationUnitId String?                @map("source_organization_unit_id")
  sourceOrganizationUnit   OrganizationUnit?      @relation("SourceOrganizationUnit", fields: [sourceOrganizationUnitId], references: [id], onDelete: Cascade)
  sourceLearningGroupId    String?                @map("source_learning_group_id")
  sourceLearningGroup      LearningGroup?         @relation("SourceLearningGroup", fields: [sourceLearningGroupId], references: [id], onDelete: Cascade)
  createdAt                DateTime               @default(now()) @map("created_at")

  @@map("user_assignment_instance_sources")
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  actorId    String?  @map("actor_id")
  actor      User?    @relation("UserAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

enum ContentProviderType {
  SCORM_1_2
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContentAttemptStatus {
  PASSED
  COMPLETED
  FAILED
  INCOMPLETE
  BROWSED
  NOT_ATTEMPTED
}

model Content {
  id                   String           @id @default(uuid())
  companyId            String           @map("company_id")
  company              Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  providerType         ContentProviderType @map("provider_type")
  title                String
  description          String?          @db.Text
  categoryId           String?          @map("category_id")
  category             ContentCategory? @relation("CategoryToContent", fields: [categoryId], references: [id], onDelete: SetNull)
  author               String?
  language             String?
  version              Int              @default(1)
  contentGroupId       String           @map("content_group_id")
  status               ContentStatus    @default(DRAFT)
  storagePathZip       String           @map("storage_path_zip")
  storagePathExtracted String           @map("storage_path_extracted")
  launchFile           String           @map("launch_file")
  manifestData         Json             @map("manifest_data")
  thumbnailPath        String?          @map("thumbnail_path")
  certificateSetting   String           @default("IGNORE") @map("certificate_setting")
  tags                 ContentTag[]
  createdById          String           @map("created_by_id")
  createdBy            User             @relation("ContentCreator", fields: [createdById], references: [id])
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  lessons              Lesson[]
  assignmentInstances  UserAssignmentInstance[]

  @@map("contents")
}

model ContentTag {
  id        String   @id @default(uuid())
  contentId String   @map("content_id")
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tag       String

  @@map("content_tags")
}

model ContentCategory {
  id               String            @id @default(uuid())
  companyId        String            @map("company_id")
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name             String
  parentCategoryId String?           @map("parent_category_id")
  parentCategory   ContentCategory?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  childCategories  ContentCategory[] @relation("CategoryHierarchy")
  contents         Content[]         @relation("CategoryToContent")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@map("content_categories")
}

model ContentAttempt {
  id                        String                 @id @default(uuid())
  userAssignmentInstanceId  String                 @map("user_assignment_instance_id")
  userAssignmentInstance    UserAssignmentInstance @relation(fields: [userAssignmentInstanceId], references: [id], onDelete: Cascade)
  attemptNumber             Int                    @map("attempt_number")
  lessonStatus              ContentAttemptStatus   @map("lesson_status")
  scoreRaw                  Decimal?               @map("score_raw") @db.Decimal(10, 2)
  scoreMin                  Decimal?               @map("score_min") @db.Decimal(10, 2)
  scoreMax                  Decimal?               @map("score_max") @db.Decimal(10, 2)
  sessionTimeSeconds        Int?                   @map("session_time_seconds")
  lessonLocation            String?                @map("lesson_location")
  suspendData               String?                @map("suspend_data") @db.Text
  objectives                Json?                  @map("objectives")
  interactions              Json?                  @map("interactions")
  startedAt                 DateTime?              @map("started_at")
  finishedAt                DateTime?              @map("finished_at")
  createdAt                 DateTime               @default(now()) @map("created_at")
  updatedAt                 DateTime               @updatedAt @map("updated_at")

  @@map("content_attempts")
}

model ProfileFieldCategory {
  id           String                   @id @default(uuid())
  companyId    String                   @map("company_id")
  company      Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  displayOrder Int                      @map("display_order")
  fields       ProfileFieldDefinition[]

  @@map("profile_field_categories")
}

enum ProfileFieldType {
  TEXT
  MULTILINE
  NUMBER
  EMAIL
  PHONE
  DATE
  CHECKBOX
  DROPDOWN
  RADIO
}

model ProfileFieldDefinition {
  id                 String                @id @default(uuid())
  companyId          String                @map("company_id")
  company            Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  categoryId         String?               @map("category_id")
  category           ProfileFieldCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  fieldKey           String?               @map("field_key")
  name               String
  description        String?               @db.Text
  fieldType          ProfileFieldType      @map("field_type")
  required           Boolean               @default(false)
  visible            Boolean               @default(true)
  editableByUser     Boolean               @default(true) @map("editable_by_user")
  displayOrder       Int                   @map("display_order")
  defaultValue       String?               @map("default_value")
  validationRules    Json?                 @map("validation_rules")
  options            Json?
  isSystemField      Boolean               @default(false) @map("is_system_field")
  externalSyncLocked Boolean               @default(false) @map("external_sync_locked")
  editableByRoles    FieldEditableByRole[]
  values             ProfileFieldValue[]

  @@unique([companyId, fieldKey])
  @@map("profile_field_definitions")
}

model FieldEditableByRole {
  fieldDefinitionId String                 @map("field_definition_id")
  fieldDefinition   ProfileFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  roleId            String                 @map("role_id")
  role              Role                   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([fieldDefinitionId, roleId])
  @@map("field_editable_by_roles")
}

model ProfileFieldValue {
  id                String                 @id @default(uuid())
  userId            String                 @map("user_id")
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  fieldDefinitionId String                 @map("field_definition_id")
  fieldDefinition   ProfileFieldDefinition @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)
  value             String?                @db.Text

  @@unique([userId, fieldDefinitionId])
  @@map("profile_field_values")
}

enum NotificationType {
  LESSON_ASSIGNED
  REMINDER
  DUE_SOON
  OVERDUE
  COMPLETION_CONFIRMATION
  CERTIFICATES
  SYSTEM_ANNOUNCEMENTS
}

model NotificationPreference {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  notificationType NotificationType @map("notification_type")
  enabled          Boolean          @default(true)

  @@unique([userId, notificationType])
  @@map("notification_preferences")
}

enum MfaPolicy {
  DISABLED
  OPTIONAL
  ENFORCED
  ROLE_BASED
}

model MfaRecoveryCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("mfa_recovery_codes")
}

model MfaPolicyRole {
  companyId String  @map("company_id")
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  roleId    String  @map("role_id")
  role      Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([companyId, roleId])
  @@map("mfa_policy_roles")
}

enum SyncSource {
  MANUAL
  ENTRA_SYNC
}

enum IdentityProviderType {
  LOCAL
  MICROSOFT_ENTRA
}

enum LoginMode {
  LOCAL_ONLY
  MICROSOFT_ONLY
  BOTH
}

enum ImportStrategy {
  ALL_USERS
  SELECTED_GROUPS
  FIRST_LOGIN
  SELECTED_GROUPS_AND_FIRST_LOGIN
}

enum SyncStatus {
  SUCCESS
  PARTIAL_FAILURE
  FAILED
  NEVER_RUN
}

enum SyncTriggerType {
  SCHEDULED
  MANUAL
}

model IdentityProviderConfig {
  id                      String               @id @default(uuid())
  companyId               String               @map("company_id")
  company                 Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  providerType            IdentityProviderType @map("provider_type")
  enabled                 Boolean              @default(false)
  tenantId                String?              @map("tenant_id")
  clientId                String?              @map("client_id")
  clientSecretEncrypted   String?              @map("client_secret_encrypted")
  redirectUri             String?              @map("redirect_uri")
  loginMode               LoginMode            @default(BOTH) @map("login_mode")
  importStrategy          ImportStrategy       @default(FIRST_LOGIN) @map("import_strategy")
  defaultSyncedUserRoleId String?              @map("default_synced_user_role_id")
  defaultSyncedUserRole   Role?                @relation(fields: [defaultSyncedUserRoleId], references: [id], onDelete: SetNull)
  lastSyncAt              DateTime?            @map("last_sync_at")
  lastSyncStatus          SyncStatus           @default(NEVER_RUN) @map("last_sync_status")
  entraGroupSelections    EntraGroupSelection[]

  @@unique([companyId, providerType])
  @@map("identity_provider_configs")
}

model EntraGroupSelection {
  id                       String                  @id @default(uuid())
  companyId                String                  @map("company_id")
  company                  Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entraGroupId             String                  @map("entra_group_id")
  entraGroupName           String                  @map("entra_group_name")
  identityProviderConfigId String?                 @map("identity_provider_config_id")
  identityProviderConfig   IdentityProviderConfig? @relation(fields: [identityProviderConfigId], references: [id], onDelete: Cascade)

  @@unique([companyId, entraGroupId])
  @@map("entra_group_selections")
}

model SyncLog {
  id                String          @id @default(uuid())
  companyId         String          @map("company_id")
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  startedAt         DateTime        @default(now()) @map("started_at")
  finishedAt        DateTime?       @map("finished_at")
  status            SyncStatus      @map("status")
  usersProcessed    Int             @default(0) @map("users_processed")
  usersFailed       Int             @default(0) @map("users_failed")
  groupsProcessed   Int             @default(0) @map("groups_processed")
  errorDetails      Json?           @map("error_details")
  triggeredBy       SyncTriggerType @map("triggered_by")
  triggeredByUserId String?         @map("triggered_by_user_id")
  triggeredByUser   User?           @relation("SyncLogTriggerer", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@map("sync_logs")
}


