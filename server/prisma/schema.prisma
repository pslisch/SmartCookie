datasource db {
  provider = "mysql"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

enum UserStatus {
  PENDING
  ACTIVE
  DISABLED
  ARCHIVED
  LOCKED
}

model User {
  id            String     @id @default(uuid())
  username      String?    @unique
  email         String?    @unique
  passwordHash  String?
  isSuperuser   Boolean    @default(false)
  isSuperuserUnique Boolean? @map("is_superuser_unique")
  recoveryEmail String?
  companyId     String?
  company       Company?   @relation(fields: [companyId], references: [id])
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  sessions      Session[]
  tokens        Token[]
  roleId        String?    @map("role_id")
  role          Role?      @relation(fields: [roleId], references: [id])
  memberships        Membership[] @relation("UserMemberships")
  createdMemberships Membership[] @relation("MembershipCreator")
  createdAssignments Assignment[] @relation("AssignmentCreator")
  ownedAssignments   Assignment[] @relation("AssignmentOwner")
  assignmentTargets  AssignmentTarget[] @relation("UserAssignmentTargets")
  userAssignmentInstances UserAssignmentInstance[] @relation("UserAssignmentInstances")
  auditLogs          AuditLog[] @relation("UserAuditLogs")

  @@unique([isSuperuserUnique], name: "is_superuser_unique_idx")
  @@map("users")
}

enum TokenPurpose {
  INVITATION
  PASSWORD_RESET
}

model Token {
  id         String       @id @default(uuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String       @unique
  purpose    TokenPurpose
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime     @default(now())

  @@map("tokens")
}

model Company {
  id               String    @id @default(uuid())
  name             String
  contactInfo      String
  setupCompletedAt DateTime?
  roleInheritanceEnabled Boolean @default(false) @map("role_inheritance_enabled")
  users            User[]
  roles            Role[]
  domain           String    @default("")
  settings         Json?
  organizationUnits OrganizationUnit[]
  learningGroups   LearningGroup[]
  lessons          Lesson[]
  courses          Course[]
  assignments      Assignment[]
  auditLogs        AuditLog[]

  @@map("companies")
}

model Role {
  id             String           @id @default(uuid())
  name           String
  isProtected    Boolean          @default(false) @map("is_protected")
  parentRoleId   String?          @map("parent_role_id")
  parentRole     Role?            @relation("RoleInheritance", fields: [parentRoleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  childRoles     Role[]           @relation("RoleInheritance")
  companyId      String           @map("company_id")
  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  users          User[]
  permissions    RolePermission[]

  @@map("roles")
}

model Permission {
  id             String           @id @default(uuid())
  module         String
  action         String
  roles          RolePermission[]

  @@unique([module, action], name: "module_action_idx")
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  @@map("sessions")
}

model OrganizationUnit {
  id                String             @id @default(uuid())
  name              String
  companyId         String             @map("company_id")
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentId          String?            @map("parent_id")
  parent            OrganizationUnit?  @relation("OUHierarchy", fields: [parentId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  children          OrganizationUnit[] @relation("OUHierarchy")
  deletedAt         DateTime?          @map("deleted_at")
  permanentDeleteAt DateTime?          @map("permanent_delete_at")
  deletionBatchId   String?            @map("deletion_batch_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  memberships       Membership[]
  assignmentTargets AssignmentTarget[]
  assignmentInstanceSources UserAssignmentInstanceSource[] @relation("SourceOrganizationUnit")

  @@map("organization_units")
}

enum GroupType {
  STATIC
  DYNAMIC
}

model LearningGroup {
  id                String             @id @default(uuid())
  name              String
  companyId         String             @map("company_id")
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parentGroupId     String?            @map("parent_group_id")
  parentGroup       LearningGroup?     @relation("GroupHierarchy", fields: [parentGroupId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  childGroups       LearningGroup[]    @relation("GroupHierarchy")
  type              GroupType          @default(STATIC)
  isTemporary       Boolean            @default(false) @map("is_temporary")
  expiresAt         DateTime?          @map("expires_at")
  reminderSentAt    DateTime?          @map("reminder_sent_at")
  deletedAt         DateTime?          @map("deleted_at")
  permanentDeleteAt DateTime?          @map("permanent_delete_at")
  deletionBatchId   String?            @map("deletion_batch_id")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  memberships       Membership[]
  assignmentTargets AssignmentTarget[]
  assignmentInstanceSources UserAssignmentInstanceSource[] @relation("SourceLearningGroup")

  @@map("learning_groups")
}

enum MembershipType {
  MEMBER
  MANAGER
}

enum MembershipStatus {
  ACTIVE
  PENDING
  ARCHIVED
}

enum MembershipSource {
  MANUAL
  AZURE_AD
  LDAP
  HR_IMPORT
  API
}

model Membership {
  id                  String             @id @default(uuid())
  userId              String             @map("user_id")
  user                User               @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  organizationUnitId  String?            @map("organization_unit_id")
  organizationUnit    OrganizationUnit?  @relation(fields: [organizationUnitId], references: [id], onDelete: Cascade)
  learningGroupId     String?            @map("learning_group_id")
  learningGroup       LearningGroup?     @relation(fields: [learningGroupId], references: [id], onDelete: Cascade)
  membershipType      MembershipType     @map("membership_type")
  status              MembershipStatus   @default(ACTIVE)
  source              MembershipSource   @default(MANUAL)
  createdById         String             @map("created_by_id")
  createdBy           User               @relation("MembershipCreator", fields: [createdById], references: [id])
  deletedAt           DateTime?          @map("deleted_at")
  deletionBatchId     String?            @map("deletion_batch_id")
  createdAt           DateTime           @default(now()) @map("created_at")

  @@map("memberships")
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

enum CourseStatus {
  DRAFT
  PUBLISHED
}

enum CompletionRule {
  MARKED_COMPLETE
  QUIZ_PASSED
  MIN_SCORE
  ACKNOWLEDGEMENT
  CUSTOM
}

enum AssignmentType {
  IMMEDIATE
  SCHEDULED
}

enum AssignmentStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  CANCELLED
  ARCHIVED
}

model Lesson {
  id                   String           @id @default(uuid())
  companyId            String           @map("company_id")
  company              Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title                String
  status               LessonStatus     @default(DRAFT)
  version              Int              @default(1)
  prerequisiteLessonId String?          @map("prerequisite_lesson_id")
  prerequisiteLesson   Lesson?          @relation("LessonPrerequisites", fields: [prerequisiteLessonId], references: [id], onDelete: SetNull)
  dependentLessons     Lesson[]         @relation("LessonPrerequisites")
  completionRule       CompletionRule   @default(MARKED_COMPLETE) @map("completion_rule")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  courseLessons        CourseLesson[]
  assignments          Assignment[]

  @@map("lessons")
}

model Course {
  id            String         @id @default(uuid())
  companyId     String         @map("company_id")
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title         String
  status        CourseStatus   @default(DRAFT)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  courseLessons CourseLesson[]

  @@map("courses")
}

model CourseLesson {
  courseId  String   @map("course_id")
  lessonId  String   @map("lesson_id")
  order     Int
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@id([courseId, lessonId])
  @@map("course_lessons")
}

model Assignment {
  id                      String             @id @default(uuid())
  companyId               String             @map("company_id")
  company                 Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lessonId                String             @map("lesson_id")
  lesson                  Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  assignmentType          AssignmentType     @map("assignment_type")
  scheduledFor            DateTime?          @map("scheduled_for")
  dueDateDefaultDays      Int?               @map("due_date_default_days")
  isMandatory             Boolean            @default(false) @map("is_mandatory")
  createdById             String             @map("created_by_id")
  createdBy               User               @relation("AssignmentCreator", fields: [createdById], references: [id])
  ownerId                 String             @map("owner_id")
  owner                   User               @relation("AssignmentOwner", fields: [ownerId], references: [id])
  status                  AssignmentStatus   @default(DRAFT)
  courseAssignmentBatchId String?            @map("course_assignment_batch_id")
  deletedAt               DateTime?          @map("deleted_at")
  permanentDeleteAt       DateTime?          @map("permanent_delete_at")
  deletionBatchId         String?            @map("deletion_batch_id")
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  targets                 AssignmentTarget[]
  userAssignmentInstances UserAssignmentInstance[]

  @@map("assignments")
}

model AssignmentTarget {
  id                 String            @id @default(uuid())
  assignmentId       String            @map("assignment_id")
  assignment         Assignment        @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId             String?           @map("user_id")
  user               User?             @relation("UserAssignmentTargets", fields: [userId], references: [id], onDelete: Cascade)
  organizationUnitId String?           @map("organization_unit_id")
  organizationUnit   OrganizationUnit? @relation(fields: [organizationUnitId], references: [id], onDelete: Cascade)
  learningGroupId    String?           @map("learning_group_id")
  learningGroup      LearningGroup?    @relation(fields: [learningGroupId], references: [id], onDelete: Cascade)
  createdAt          DateTime          @default(now()) @map("created_at")

  @@map("assignment_targets")
}

enum UserAssignmentInstanceStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum AssignmentSourceType {
  MANUAL
  ORGANIZATION_UNIT
  LEARNING_GROUP
  SELF_ASSIGNED
  MANDATORY
  API
}

model UserAssignmentInstance {
  id                String                       @id @default(uuid())
  assignmentId      String                       @map("assignment_id")
  assignment        Assignment                   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  userId            String                       @map("user_id")
  user              User                         @relation("UserAssignmentInstances", fields: [userId], references: [id], onDelete: Cascade)
  status            UserAssignmentInstanceStatus @default(ACTIVE)
  dueDate           DateTime?                    @map("due_date")
  startedAt         DateTime?                    @map("started_at")
  completedAt       DateTime?                    @map("completed_at")
  progressPercent   Int                          @default(0) @map("progress_percent")
  deletedAt         DateTime?                    @map("deleted_at")
  permanentDeleteAt DateTime?                    @map("permanent_delete_at")
  deletionBatchId   String?                      @map("deletion_batch_id")
  lastReminderSentAt DateTime?                   @map("last_reminder_sent_at")
  createdAt         DateTime                     @default(now()) @map("created_at")
  updatedAt         DateTime                     @updatedAt @map("updated_at")
  sources           UserAssignmentInstanceSource[]

  @@unique([assignmentId, userId])
  @@map("user_assignment_instances")
}

model UserAssignmentInstanceSource {
  id                       String                 @id @default(uuid())
  userAssignmentInstanceId String                 @map("user_assignment_instance_id")
  userAssignmentInstance   UserAssignmentInstance @relation(fields: [userAssignmentInstanceId], references: [id], onDelete: Cascade)
  sourceType               AssignmentSourceType   @map("source_type")
  sourceOrganizationUnitId String?                @map("source_organization_unit_id")
  sourceOrganizationUnit   OrganizationUnit?      @relation("SourceOrganizationUnit", fields: [sourceOrganizationUnitId], references: [id], onDelete: Cascade)
  sourceLearningGroupId    String?                @map("source_learning_group_id")
  sourceLearningGroup      LearningGroup?         @relation("SourceLearningGroup", fields: [sourceLearningGroupId], references: [id], onDelete: Cascade)
  createdAt                DateTime               @default(now()) @map("created_at")

  @@map("user_assignment_instance_sources")
}

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  actorId    String?  @map("actor_id")
  actor      User?    @relation("UserAuditLogs", fields: [actorId], references: [id], onDelete: SetNull)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

