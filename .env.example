# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PORT: The port the Express application listens on (defaults to 3000).
PORT=3000

# DATABASE_URL: The connection string for the MariaDB/MySQL database.
DATABASE_URL="mysql://smartcookie:smartcookie_pass@127.0.0.1:3306/smartcookie"

# SESSION_SECRET: Secret used to sign session cookies.
SESSION_SECRET="some-long-random-string-at-least-32-chars-long"

# SMTP Settings for old-email notification on recovery-email change
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="2525"
SMTP_USER="smtp_user"
SMTP_PASS="smtp_pass"
SMTP_FROM="no-reply@smartcookie.ai"

# Content storage root path (outside web-servable root)
CONTENT_STORAGE_PATH="/opt/smartcookie/content-storage"

# Encryption Key: Required for encrypting/decrypting secrets at rest (e.g. TOTP secrets, tokens).
# ENCRYPTION_KEY is the preferred variable; MFA_ENCRYPTION_KEY is still supported for backward compatibility.
ENCRYPTION_KEY="some-long-random-string-at-least-32-chars-long"
MFA_ENCRYPTION_KEY="some-long-random-string-at-least-32-chars-long"



